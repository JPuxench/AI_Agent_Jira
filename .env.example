# Jira Agent Configuration
# Copy this file to .env and fill in your values
# IMPORTANT: Never commit .env to version control!

# ===========================================
# JIRA CONNECTION
# ===========================================
JIRA_URL=https://jira.example.com

# ===========================================
# AUTHENTICATION (choose one method)
# ===========================================

# Option 1: Personal Access Token (PAT) - RECOMMENDED for Jira Server
# Generate at: Jira > Profile > Personal Access Tokens
JIRA_PAT=your_personal_access_token_here

# Option 2: Basic Auth - For Jira Cloud (atlassian.net)
# Generate API token at: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_USERNAME=your_email@example.com
# JIRA_API_TOKEN=your_api_token_here

# ===========================================
# OPTIONAL SETTINGS
# ===========================================

# Default project to filter tickets (optional)
JIRA_PROJECT=YOUR_PROJECT_KEY

# Maximum number of tickets to fetch (default: 50)
JIRA_LIMIT=50
