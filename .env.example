# Jira Agent Configuration
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env:  cp .env.example .env
# 2. Generate your PAT at: https://jira.sage.com > Profile > Personal Access Tokens
# 3. Paste your PAT below
# 4. IMPORTANT: Never commit .env to version control!

# Jira Server URL
JIRA_URL=https://jira.sage.com

# Personal Access Token (PAT)
# Generate at: Jira > Click your avatar > Profile > Personal Access Tokens > Create token
JIRA_PAT=paste_your_token_here

# Project key (optional - filters tickets to this project)
JIRA_PROJECT=EBNC

# Maximum tickets to fetch (optional, default: 50)
JIRA_LIMIT=50
